+import { useState } from 'react';
+import { useNavigate } from 'react-router-dom';
+import { mockListings } from './mockData';
+
+export function useMiniSearch() {
+    const [query, setQuery] = useState('');
+    const [filteredResults, setFilteredResults] = useState([]);
+    const navigate = useNavigate();
+
+    const handleInputChange = (e) => {
+        const value = e.target.value;
+        setQuery(value);
+
+        if (value.trim() === '') {
+            setFilteredResults([]);
+            return;
+        }
+
+        // ფილტრაცია სახელითა და საგნით
+        const filtered = mockListings.filter((item) =>
+            item.name.toLowerCase().includes(value.toLowerCase()) ||
+            item.subject.toLowerCase().includes(value.toLowerCase())
+        );
+        setFilteredResults(filtered);
+    };
+
+    // კონკრეტულ პროფილზე გადასვლა
+    const handleItemClick = (id) => {
+        setQuery('');
+        setFilteredResults([]);
+        navigate(`/listing/${id}`);
+    };
+
+    // ძებნის გვერდზე გადასვლა (ცარიელზეც)
+    const handleSearchSubmit = (e) => {
+        e.preventDefault();
+        setFilteredResults([]);
+        navigate(`/search?query=${query.trim()}`);
+    };
+
+    // გარეთ გამოგვაქვს ყველაფერი, რაც ვიზუალს დასჭირდება
+    return {
+        query,
+        filteredResults,
+        handleInputChange,
+        handleItemClick,
+        handleSearchSubmit
+    };
+}
